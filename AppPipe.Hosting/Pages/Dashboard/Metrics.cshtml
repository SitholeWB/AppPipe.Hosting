@page "/dashboard/metrics"
@{
    ViewData["Title"] = "Metrics";
}

@section Styles {
    <style>
        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 1.5rem;
        }

        .metric-card {
            background: var(--panel-bg);
            border: 1px solid var(--border-color);
            border-radius: 14px;
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            box-shadow: var(--shadow-md);
            transition: all 0.2s;
        }
        .metric-card:hover {
            box-shadow: var(--shadow-lg);
            transform: translateY(-2px);
        }

        .metric-card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .metric-card-title {
            font-size: 1.1rem;
            font-weight: 700;
            color: var(--text-main);
            letter-spacing: -0.01em;
        }

        .metric-chart-container {
            height: 140px;
            background: var(--bg-color);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            position: relative;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .metric-stats {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 0.4rem;
        }

        .stat-pill {
            background: var(--panel-solid);
            border: 1px solid var(--border-color);
            padding: 0.4rem;
            border-radius: 8px;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .stat-label {
            font-size: 0.65rem;
            color: var(--text-muted);
            font-weight: 700;
            text-transform: uppercase;
        }

        .stat-val {
            font-size: 0.85rem;
            font-weight: 700;
            color: var(--text-main);
            font-family: 'JetBrains Mono', monospace;
            margin-top: 0.15rem;
        }

        .chart-tooltip {
            position: absolute;
            background: rgba(17, 24, 39, 0.95);
            border: 1px solid var(--border-color);
            border-radius: 6px;
            padding: 6px 10px;
            color: #ffffff;
            font-size: 0.725rem;
            pointer-events: none;
            box-shadow: var(--shadow-md);
            display: none;
            z-index: 10;
            font-family: 'JetBrains Mono', monospace;
        }
    </style>
}

<div class="filter-bar">
    <div class="search-container">
        <input type="text" class="aspire-input" placeholder="Filter metric keys (cpu, memory, request)..." id="metric-search" oninput="onMetricSearchChange(this.value)">
    </div>
    <div class="pill-group" id="metric-service-pills">
        <!-- Dynamic Pills -->
    </div>
    <div class="pill-group">
        <button class="pill-btn active" onclick="setMetricTimeFilter('All', this)">All Time</button>
        <button class="pill-btn" onclick="setMetricTimeFilter('5m', this)">Last 5m</button>
        <button class="pill-btn" onclick="setMetricTimeFilter('15m', this)">Last 15m</button>
        <button class="pill-btn" onclick="setMetricTimeFilter('1h', this)">Last 1h</button>
    </div>
</div>

<div class="metrics-grid" id="metrics-cards-container">
    <!-- Sparkline cards -->
</div>

@section Scripts {
    <script>
        state.activeTab = 'metrics';
        state.selectedMetricService = localStorage.getItem('apppipe_metrics_service') || 'All';
        state.metricTimeFilter = 'All';
        state.metricSearchTerm = '';

        function onMetricSearchChange(val) {
            state.metricSearchTerm = val;
            renderActiveTab();
        }

        function setMetricServiceFilter(srv, btn) {
            state.selectedMetricService = srv;
            localStorage.setItem('apppipe_metrics_service', srv);
            btn.parentNode.querySelectorAll('.pill-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            renderActiveTab();
        }

        function setMetricTimeFilter(range, btn) {
            state.metricTimeFilter = range;
            btn.parentNode.querySelectorAll('.pill-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            renderActiveTab();
        }

        const chartsMetadata = {};

        function renderActiveTab() {
            const datapoints = state.metrics; // Already flat parsed on the server!

            const servicePills = document.getElementById('metric-service-pills');
            const distinctServices = [...new Set(datapoints.map(dp => dp.serviceName))];
            let pillsHtml = `<button class="pill-btn ${state.selectedMetricService === 'All' ? 'active' : ''}" onclick="setMetricServiceFilter('All', this)">All Services</button>`;
            distinctServices.forEach(srv => {
                pillsHtml += `<button class="pill-btn ${state.selectedMetricService === srv ? 'active' : ''}" onclick="setMetricServiceFilter('${srv}', this)">${srv}</button>`;
            });
            servicePills.innerHTML = pillsHtml;

            // Group by name/service
            const grouped = {};
            const now = new Date();

            datapoints.forEach(dp => {
                if (state.selectedMetricService !== 'All' && dp.serviceName !== state.selectedMetricService) return;
                if (state.metricSearchTerm && !dp.metricName.toLowerCase().includes(state.metricSearchTerm.toLowerCase())) return;

                if (state.metricTimeFilter !== 'All') {
                    const timestampDate = new Date(dp.timestamp);
                    const diffMins = (now - timestampDate) / 60000;
                    if (state.metricTimeFilter === '5m' && diffMins > 5) return;
                    if (state.metricTimeFilter === '15m' && diffMins > 15) return;
                    if (state.metricTimeFilter === '1h' && diffMins > 60) return;
                }

                const key = `${dp.metricName}||${dp.serviceName}`;
                if (!grouped[key]) {
                    grouped[key] = {
                        metricName: dp.metricName,
                        serviceName: dp.serviceName,
                        points: []
                    };
                }
                
                grouped[key].points.push({
                    ...dp,
                    timestamp: new Date(dp.timestamp)
                });
            });

            const cardsContainer = document.getElementById('metrics-cards-container');
            const groupedList = Object.values(grouped);
            
            if (groupedList.length === 0) {
                cardsContainer.innerHTML = '<div class="empty-state" style="grid-column: 1/-1; text-align:center; padding:3rem;"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="18" y1="20" x2="18" y2="10"></line><line x1="12" y1="20" x2="12" y2="4"></line><line x1="6" y1="20" x2="6" y2="14"></line></svg><div class="empty-state-title" style="font-weight:700; margin-top:0.5rem;">No Metric Data Available</div><div style="color:var(--text-muted);">Ensure your microservices export metrics to telemetry endpoint.</div></div>';
                return;
            }

            groupedList.sort((a,b) => a.metricName.localeCompare(b.metricName));

            let html = '';
            groupedList.forEach((item, idx) => {
                item.points.sort((a,b) => a.timestamp - b.timestamp);
                
                const vals = item.points.map(p => p.value);
                const min = Math.min(...vals);
                const max = Math.max(...vals);
                const avg = vals.reduce((a,b) => a+b, 0) / vals.length;

                const sparklineSvg = drawSparklineSvg(item.points, min, max, idx);

                html += `
                    <div class="metric-card">
                        <div class="metric-card-header">
                            <span class="metric-card-title">${escapeHtml(item.metricName)}</span>
                            <span class="badge badge-info" style="font-size: 0.65rem; font-weight:700;">${item.serviceName}</span>
                        </div>
                        <div class="metric-chart-container" onmousemove="showChartTooltip(event, ${idx})" onmouseleave="hideChartTooltip(${idx})" id="chart-container-${idx}">
                            ${sparklineSvg}
                            <div class="chart-tooltip" id="tooltip-${idx}"></div>
                        </div>
                        <div class="metric-stats">
                            <div class="stat-pill"><span class="stat-label">Min</span><span class="stat-val">${min.toFixed(1)}</span></div>
                            <div class="stat-pill"><span class="stat-label" style="color:var(--accent);">Max</span><span class="stat-val">${max.toFixed(1)}</span></div>
                            <div class="stat-pill"><span class="stat-label">Avg</span><span class="stat-val">${avg.toFixed(1)}</span></div>
                            <div class="stat-pill"><span class="stat-label">Samples</span><span class="stat-val">${item.points.length}</span></div>
                        </div>
                    </div>
                `;
            });
            cardsContainer.innerHTML = html;
        }

        function drawSparklineSvg(points, min, max, chartIdx) {
            if (points.length < 2) {
                return '<div style="font-size:0.75rem; color:var(--text-muted);">Waiting for more points...</div>';
            }

            const width = 360;
            const height = 140;
            const padding = 12;
            
            const range = max - min || 1;
            const tempStart = points[0].timestamp.getTime();
            const timeRange = points[points.length - 1].timestamp.getTime() - tempStart || 1;

            const coords = points.map(pt => {
                const x = padding + ((pt.timestamp.getTime() - tempStart) / timeRange) * (width - 2 * padding);
                const y = height - padding - ((pt.value - min) / range) * (height - 2 * padding);
                return { x, y, timestamp: pt.timestamp, value: pt.value };
            });

            chartsMetadata[chartIdx] = { coords, width, height };

            let dPath = `M ${coords[0].x} ${coords[0].y}`;
            for (let i = 1; i < coords.length; i++) {
                dPath += ` L ${coords[i].x} ${coords[i].y}`;
            }

            const dFill = `${dPath} L ${coords[coords.length - 1].x} ${height} L ${coords[0].x} ${height} Z`;
            const strokeColor = 'var(--accent)';
            const gradId = `chartGrad-${chartIdx}-${Math.floor(Math.random()*1000)}`;

            return `
                <svg class="metric-chart-svg" viewBox="0 0 ${width} ${height}" style="overflow:visible; width:100%; height:100%;">
                    <defs>
                        <linearGradient id="${gradId}" x1="0" y1="0" x2="0" y2="1">
                            <stop offset="0%" stop-color="var(--accent)" stop-opacity="0.35"/>
                            <stop offset="100%" stop-color="var(--accent)" stop-opacity="0.0"/>
                        </linearGradient>
                    </defs>
                    <path d="${dFill}" fill="url(#${gradId})" />
                    <path d="${dPath}" fill="none" stroke="${strokeColor}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            `;
        }

        function showChartTooltip(event, idx) {
            const meta = chartsMetadata[idx];
            if (!meta) return;

            const container = document.getElementById(`chart-container-${idx}`);
            const tooltip = document.getElementById(`tooltip-${idx}`);
            
            const rect = container.getBoundingClientRect();
            const mouseX = event.clientX - rect.left;
            
            const svgX = (mouseX / rect.width) * meta.width;

            let closest = meta.coords[0];
            let minDist = Math.abs(closest.x - svgX);
            for (let i = 1; i < meta.coords.length; i++) {
                const dist = Math.abs(meta.coords[i].x - svgX);
                if (dist < minDist) {
                    minDist = dist;
                    closest = meta.coords[i];
                }
            }

            const tooltipX = (closest.x / meta.width) * rect.width;
            const tooltipY = (closest.y / meta.height) * rect.height;

            tooltip.style.left = `${tooltipX - 40}px`;
            tooltip.style.top = `${tooltipY - 45}px`;
            tooltip.style.display = 'block';
            tooltip.innerHTML = `Value: ${closest.value.toFixed(1)}<br/>${closest.timestamp.toLocaleTimeString()}`;
        }

        function hideChartTooltip(idx) {
            const tooltip = document.getElementById(`tooltip-${idx}`);
            if (tooltip) tooltip.style.display = 'none';
        }
    </script>
}
