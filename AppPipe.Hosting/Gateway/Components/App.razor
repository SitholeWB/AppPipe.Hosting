<!DOCTYPE html>
<html lang="en">
@using Microsoft.Extensions.Configuration
@inject NavigationManager NavigationManager
@inject IConfiguration Config

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="@GetBaseHref()" />
    <link rel="stylesheet" href="_content/AppPipe.Hosting/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="_content/AppPipe.Hosting/app.css" />
    <link rel="stylesheet" href="@(System.Reflection.Assembly.GetEntryAssembly()?.GetName().Name + ".styles.css")" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="CurrentRenderMode" />
</head>

<body>
    <Routes @rendermode="CurrentRenderMode" />
    <script src="_framework/blazor.web.js"></script>
    <script>
        window.apppipe_localstorage_get = (key) => localStorage.getItem(key);
        window.apppipe_localstorage_set = (key, value) => localStorage.setItem(key, value);
        window.apppipe_localstorage_remove = (key) => localStorage.removeItem(key);
        window.apppipe_clipboard_copy = (text) => {
            if (navigator.clipboard) {
                navigator.clipboard.writeText(text);
            } else {
                var textArea = document.createElement("textarea");
                textArea.value = text;
                document.body.appendChild(textArea);
                textArea.select();
                document.execCommand("copy");
                document.body.removeChild(textArea);
            }
        };
        window.apppipe_focus_element = (id) => {
            var el = document.getElementById(id);
            if (el) el.focus();
        };
        window.apppipe_download_csv = (filename, base64Content) => {
            var link = document.createElement('a');
            link.download = filename;
            link.href = 'data:text/csv;base64,' + base64Content;
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        };
        document.addEventListener('keydown', function (e) {
            if (e.key === '/' && document.activeElement.tagName !== 'INPUT' && document.activeElement.tagName !== 'TEXTAREA') {
                e.preventDefault();
                var el = document.getElementById('log-search');
                if (el) el.focus();
            }
        });
    </script>
</body>

</html>

@code {
    private Microsoft.AspNetCore.Components.IComponentRenderMode CurrentRenderMode =>
        Microsoft.AspNetCore.Components.Web.RenderMode.InteractiveServer;

    private string GetBaseHref()
    {
        var baseUri = NavigationManager.BaseUri;
        if (Uri.TryCreate(baseUri, UriKind.Absolute, out var uri))
        {
            var path = uri.AbsolutePath;
            return path.EndsWith("/") ? path : path + "/";
        }
        return "/";
    }
}
