@inherits LayoutComponentBase

<div class="aspire-layout" data-theme="@currentTheme">
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
                </svg>
            </div>
            <span>AppPipe.NET</span>
        </div>
        <nav class="sidebar-nav">
            <NavLink href="dashboard" Match="NavLinkMatch.All" class="nav-item">
                <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none"><rect x="3" y="3" width="7" height="7"></rect><rect x="14" y="3" width="7" height="7"></rect><rect x="14" y="14" width="7" height="7"></rect><rect x="3" y="14" width="7" height="7"></rect></svg>
                Resources
            </NavLink>
            <NavLink href="logs" class="nav-item">
                <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>
                Console
            </NavLink>
            <NavLink href="traces" class="nav-item">
                <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none"><circle cx="18" cy="18" r="3"></circle><circle cx="6" cy="6" r="3"></circle><path d="M13 6h3a2 2 0 0 1 2 2v7"></path><line x1="6" y1="9" x2="6" y2="21"></line></svg>
                Traces
            </NavLink>
            <NavLink href="metrics" class="nav-item">
                <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
                Metrics
            </NavLink>
            <NavLink href="diagnostics" class="nav-item">
                <svg viewBox="0 0 24 24" width="18" height="18" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"></circle><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"></path></svg>
                Diagnostics
            </NavLink>
        </nav>
        
        <div class="sidebar-footer">
            <button class="theme-toggle" @onclick="ToggleTheme">
                @if (currentTheme == "dark")
                {
                    <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
                    <span>Light Mode</span>
                }
                else
                {
                    <svg viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
                    <span>Dark Mode</span>
                }
            </button>
        </div>
    </aside>

    <!-- Main Content -->
    <div class="main-wrapper">
        <header class="top-header">
            <div class="header-title">
                <!-- Title depends on the page, but we'll leave it generic here or let pages render their own headers -->
                <span class="environment-badge">Development</span>
            </div>
            <div class="header-actions">
                <a href="https://github.com/SitholeWB/AppPipe.Hosting" target="_blank" class="header-link">Help</a>
            </div>
        </header>

        <main class="main-content">
            <CascadingValue Value="currentTheme">
                @Body
            </CascadingValue>
        </main>
    </div>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

<style>
    :root {
        /* Light Theme (Aspire-like) */
        --bg-color: #f8fafc;
        --sidebar-bg: rgba(255, 255, 255, 0.75);
        --header-bg: rgba(255, 255, 255, 0.75);
        --panel-bg: #ffffff;
        --panel-bg-hover: #f1f5f9;
        --item-bg: #ffffff;
        --accent: #0284c7; /* Aspire blue */
        --text-main: #0f172a;
        --text-muted: #64748b;
        --border-color: rgba(226, 232, 240, 0.8);
        --border-hover: #cbd5e1;
        
        --table-header-bg: #f8fafc;
        --table-border: #f1f5f9;
        
        --badge-success-bg: #dcfce7;
        --badge-success-text: #166534;
        --badge-error-bg: #fee2e2;
        --badge-error-text: #991b1b;
        --badge-info-bg: #e0f2fe;
        --badge-info-text: #075985;
    }

    [data-theme="dark"] {
        /* Dark Theme (Aspire-like) */
        --bg-color: #0b0f19;
        --sidebar-bg: rgba(20, 26, 42, 0.75);
        --header-bg: rgba(20, 26, 42, 0.75);
        --panel-bg: #141a2a;
        --panel-bg-hover: #1e293b;
        --item-bg: #141a2a;
        --accent: #38bdf8;
        --text-main: #e2e8f0;
        --text-muted: #94a3b8;
        --border-color: rgba(51, 65, 85, 0.5);
        --border-hover: #475569;
        
        --table-header-bg: #0b0f19;
        --table-border: #1e293b;
        
        --badge-success-bg: rgba(34, 197, 94, 0.15);
        --badge-success-text: #4ade80;
        --badge-error-bg: rgba(239, 68, 68, 0.1);
        --badge-error-text: #fca5a5;
        --badge-info-bg: rgba(56, 189, 248, 0.1);
        --badge-info-text: #38bdf8;
    }

    body {
        margin: 0;
        font-family: 'Outfit', 'Segoe UI', Inter, -apple-system, BlinkMacSystemFont, Roboto, sans-serif;
        background-color: var(--bg-color);
        color: var(--text-main);
        -webkit-font-smoothing: antialiased;
    }

    /* Layout */
    .aspire-layout {
        display: flex;
        min-height: 100vh;
        background-color: var(--bg-color);
        color: var(--text-main);
    }

    /* Sidebar */
    .sidebar {
        width: 260px;
        background-color: var(--sidebar-bg);
        backdrop-filter: blur(16px) saturate(180%);
        -webkit-backdrop-filter: blur(16px) saturate(180%);
        border-right: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        position: fixed;
        top: 0;
        bottom: 0;
        left: 0;
        z-index: 10;
    }

    .sidebar-brand {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1.25rem 1.5rem;
        font-size: 1.15rem;
        font-weight: 700;
        letter-spacing: -0.025em;
        color: var(--text-main);
        border-bottom: 1px solid var(--border-color);
    }

    .brand-icon {
        color: var(--accent);
        display: flex;
        align-items: center;
        filter: drop-shadow(0 0 8px rgba(56, 189, 248, 0.3));
    }

    .sidebar-nav {
        flex: 1;
        padding: 1.25rem 0.75rem;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .nav-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.65rem 0.85rem;
        color: var(--text-muted);
        text-decoration: none;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 500;
        transition: all 0.2s ease;
    }

    .nav-item:hover {
        background-color: var(--panel-bg-hover);
        color: var(--text-main);
        transform: translateX(2px);
    }
    
    .nav-item.active {
        background-color: rgba(2, 132, 199, 0.08);
        color: var(--accent);
        font-weight: 600;
    }
    [data-theme="dark"] .nav-item.active {
        background-color: rgba(56, 189, 248, 0.08);
    }

    .nav-item svg {
        color: var(--text-muted);
        transition: color 0.2s;
    }
    .nav-item.active svg {
        color: var(--accent);
    }
    .nav-item:hover svg {
        color: var(--text-main);
    }

    .sidebar-footer {
        padding: 1rem;
        border-top: 1px solid var(--border-color);
    }

    .theme-toggle {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        width: 100%;
        background: transparent;
        border: none;
        color: var(--text-muted);
        padding: 0.6rem;
        border-radius: 8px;
        cursor: pointer;
        font-family: inherit;
        font-size: 0.85rem;
        font-weight: 500;
        text-align: left;
        transition: all 0.2s;
    }

    .theme-toggle:hover {
        background-color: var(--panel-bg-hover);
        color: var(--text-main);
    }

    /* Main Content Wrapper */
    .main-wrapper {
        flex: 1;
        margin-left: 260px;
        display: flex;
        flex-direction: column;
    }

    .top-header {
        height: 60px;
        background-color: var(--header-bg);
        backdrop-filter: blur(16px) saturate(180%);
        -webkit-backdrop-filter: blur(16px) saturate(180%);
        border-bottom: 1px solid var(--border-color);
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 2rem;
        position: sticky;
        top: 0;
        z-index: 5;
    }
    
    .environment-badge {
        font-size: 0.7rem;
        font-weight: 700;
        padding: 0.25rem 0.6rem;
        border-radius: 6px;
        background: var(--badge-info-bg);
        color: var(--badge-info-text);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    
    .header-link {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.9rem;
        font-weight: 500;
        transition: color 0.2s;
    }
    
    .header-link:hover {
        color: var(--text-main);
    }

    .main-content {
        padding: 2.25rem 2rem;
        flex: 1;
    }

    /* Global Table Styles (Aspire-like) */
    .aspire-table-container {
        background: var(--panel-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 30px -10px rgba(0, 0, 0, 0.05);
    }
    [data-theme="dark"] .aspire-table-container {
        box-shadow: 0 10px 40px -15px rgba(0, 0, 0, 0.3);
    }
    
    .aspire-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.9rem;
    }
    
    .aspire-table th {
        background: var(--table-header-bg);
        color: var(--text-muted);
        font-weight: 600;
        text-align: left;
        padding: 0.85rem 1.25rem;
        border-bottom: 1px solid var(--border-color);
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    
    .aspire-table td {
        padding: 0.9rem 1.25rem;
        border-bottom: 1px solid var(--table-border);
        color: var(--text-main);
    }
    
    .aspire-table tbody tr:hover td {
        background-color: var(--panel-bg-hover);
    }
    
    .aspire-table tbody tr:last-child td {
        border-bottom: none;
    }
</style>

@code {
    private string currentTheme = "dark";

    private void ToggleTheme()
    {
        currentTheme = currentTheme == "dark" ? "light" : "dark";
    }
}
