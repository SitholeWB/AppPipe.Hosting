@page "/logs"
@using AppPipe.Hosting
@inject ITelemetryStore Store
@implements IDisposable

<PageTitle>Console Logs - AppPipe.NET</PageTitle>

<div class="page-container">
    <div class="page-header">
        <h1>Console Logs</h1>
        <div class="header-actions">
            <input type="text" @bind="searchTerm" @bind:event="oninput" placeholder="Filter logs..." class="aspire-input" />
            <button class="aspire-btn" @onclick="() => isPaused = !isPaused">
                @(isPaused ? "▶ Resume" : "⏸ Pause")
            </button>
        </div>
    </div>

    <div class="aspire-table-container console-container">
        <table class="aspire-table console-table">
            <thead>
                <tr>
                    <th style="width: 150px">Timestamp</th>
                    <th style="width: 100px">Level</th>
                    <th style="width: 200px">Service</th>
                    <th>Message</th>
                </tr>
            </thead>
            <tbody>
                @if (!GetFilteredLogs().Any())
                {
                    <tr>
                        <td colspan="4" class="empty-cell">Waiting for logs...</td>
                    </tr>
                }
                else
                {
                    @foreach (var log in GetFilteredLogs())
                    {
                        var severityClass = log.Severity?.ToLowerInvariant() ?? "info";

                        <tr>
                            <td class="font-mono">@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss.fff")</td>
                            <td><span class="sev-badge @severityClass">@log.Severity</span></td>
                            <td class="service-col">@log.ServiceName</td>
                            <td class="msg-col">
                                @if (log.Attributes != null && log.Attributes.Any())
                                {
                                    <details class="log-details-accordion">
                                        <summary class="log-summary-msg">@log.Message</summary>
                                        <div class="waterfall-container">
                                            <div style="display: grid; grid-template-columns: auto 1fr; gap: 0.25rem 1.5rem; font-family: monospace; font-size: 0.8rem; margin-top: 0.5rem;">
                                                @foreach (var attr in log.Attributes)
                                                {
                                                    <div style="color: var(--text-muted); font-weight: 500;">@attr.Key</div>
                                                    <div style="word-break: break-all;">@attr.Value</div>
                                                }
                                            </div>
                                        </div>
                                    </details>
                                }
                                else
                                {
                                    @log.Message
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .page-container {
        display: flex;
        flex-direction: column;
        height: 100%;
    }
    
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
    }
    
    .page-header h1 {
        font-size: 1.5rem;
        font-weight: 600;
        margin: 0;
    }
    
    .header-actions {
        display: flex;
        gap: 1rem;
    }
    
    .aspire-input {
        background: var(--item-bg);
        border: 1px solid var(--border-color);
        color: var(--text-main);
        padding: 0.4rem 0.75rem;
        border-radius: 4px;
        font-family: inherit;
        font-size: 0.9rem;
        width: 250px;
    }
    
    .aspire-input:focus {
        outline: none;
        border-color: var(--accent);
    }
    
    .aspire-btn {
        background: var(--item-bg);
        border: 1px solid var(--border-color);
        color: var(--text-main);
        padding: 0.4rem 1rem;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.9rem;
        font-weight: 500;
    }
    
    .aspire-btn:hover {
        background: var(--panel-bg-hover);
    }

    .empty-cell {
        text-align: center;
        color: var(--text-muted);
        padding: 3rem !important;
    }

    .font-mono { font-family: 'Consolas', 'Courier New', monospace; font-size: 0.85rem; }
    
    .console-table th {
        position: sticky;
        top: 0;
        z-index: 2;
    }

    .console-table td {
        vertical-align: top;
        font-family: 'Consolas', 'Courier New', monospace;
        font-size: 0.85rem;
    }

    .service-col {
        color: var(--accent);
    }

    .msg-col {
        word-break: break-all;
    }

    .sev-badge {
        font-weight: 600;
        font-size: 0.75rem;
        padding: 0.1rem 0.4rem;
        border-radius: 3px;
        text-transform: uppercase;
    }
    
    .sev-badge.info, .sev-badge.information { background: var(--badge-info-bg); color: var(--badge-info-text); }
    .sev-badge.warn, .sev-badge.warning { background: rgba(234, 179, 8, 0.15); color: #ca8a04; }
    .sev-badge.error, .sev-badge.fatal { background: var(--badge-error-bg); color: var(--badge-error-text); }
    .sev-badge.debug, .sev-badge.trace { background: var(--border-color); color: var(--text-muted); }
    
    [data-theme="dark"] .sev-badge.warn, [data-theme="dark"] .sev-badge.warning { color: #facc15; }

    .log-details-accordion {
        width: 100%;
    }
    
    .log-summary-msg {
        cursor: pointer;
        user-select: none;
        outline: none;
        font-weight: 500;
    }
    
    .log-summary-msg:hover {
        color: var(--accent);
    }

    .waterfall-container {
        padding: 0.75rem 1rem;
        border: 1px solid var(--border-color);
        background: rgba(0, 0, 0, 0.02);
        border-radius: 4px;
        margin-top: 0.5rem;
    }
    
    [data-theme="dark"] .waterfall-container {
        background: rgba(255, 255, 255, 0.02);
    }
</style>

@code {
    private bool isPaused = false;
    private string searchTerm = "";
    private List<ParsedLog> cachedLogs = new();
    // Toggle state is now handled natively by HTML <details> tag

    protected override void OnInitialized()
    {
        Store.OnTelemetryReceived += OnTelemetryReceived;
        UpdateCache();
    }

    private void OnTelemetryReceived()
    {
        if (!isPaused)
        {
            InvokeAsync(() => 
            {
                UpdateCache();
                StateHasChanged();
            });
        }
    }
    
    private void UpdateCache()
    {
        cachedLogs = Store.Logs
            .OrderByDescending(l => l.Timestamp)
            .Take(200)
            .ToList();
    }
    
    private IEnumerable<ParsedLog> GetFilteredLogs()
    {
        if (string.IsNullOrWhiteSpace(searchTerm)) return cachedLogs;
        
        var lowerSearch = searchTerm.ToLowerInvariant();
        return cachedLogs.Where(l => 
            l.Message?.ToLowerInvariant().Contains(lowerSearch) == true || 
            l.ServiceName?.ToLowerInvariant().Contains(lowerSearch) == true
        );
    }

    public void Dispose()
    {
        Store.OnTelemetryReceived -= OnTelemetryReceived;
    }
}
