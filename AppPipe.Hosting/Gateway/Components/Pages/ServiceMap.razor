@page "/service-map"
@using AppPipe.Hosting
@using Microsoft.Extensions.Configuration
@using System.Globalization
@inject ITelemetryStore Store
@inject IConfiguration Config
@implements IDisposable

<PageTitle>Service Map - AppPipe.NET</PageTitle>

<div class="page-container">
    <div class="page-header">
        <div class="page-header-left">
            <h1>Service Map</h1>
            <span class="summary-badge">
                @_nodes.Count service@(_nodes.Count == 1 ? "" : "s"),
                @_edges.Count edge@(_edges.Count == 1 ? "" : "s")
            </span>
        </div>
        <div class="header-actions">
            <button class="aspire-btn refresh-btn" @onclick="Recompute">
                <svg class="refresh-icon" viewBox="0 0 24 24">
                    <path d="M17.65 6.35C16.2 4.9 14.21 4 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08c-.82 2.33-3.04 4-5.65 4-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z" />
                </svg>
                Refresh
            </button>
        </div>
    </div>

    <!-- SVG Graph -->
    <div class="graph-card">
        <svg viewBox="0 0 600 500"
             xmlns="http://www.w3.org/2000/svg"
             class="service-map-svg"
             aria-label="Service dependency graph">

            <defs>
                <!-- Healthy arrowhead (green-ish) -->
                <marker id="arrow-healthy"
                        markerWidth="10"
                        markerHeight="7"
                        refX="9"
                        refY="3.5"
                        orient="auto"
                        markerUnits="strokeWidth">
                    <polygon points="0 0, 10 3.5, 0 7" fill="#22c55e" />
                </marker>
                <!-- Degraded arrowhead (amber) -->
                <marker id="arrow-degraded"
                        markerWidth="10"
                        markerHeight="7"
                        refX="9"
                        refY="3.5"
                        orient="auto"
                        markerUnits="strokeWidth">
                    <polygon points="0 0, 10 3.5, 0 7" fill="#f59e0b" />
                </marker>
                <!-- Failing arrowhead (red) -->
                <marker id="arrow-failing"
                        markerWidth="10"
                        markerHeight="7"
                        refX="9"
                        refY="3.5"
                        orient="auto"
                        markerUnits="strokeWidth">
                    <polygon points="0 0, 10 3.5, 0 7" fill="#ef4444" />
                </marker>
                <!-- Drop shadow filter for nodes -->
                <filter id="node-shadow" x="-30%" y="-30%" width="160%" height="160%">
                    <feDropShadow dx="0" dy="2" stdDeviation="3" flood-color="rgba(0,0,0,0.18)" flood-opacity="1" />
                </filter>
            </defs>

            @if (_nodes.Count == 0)
            {
                <!-- Empty state -->
                <g>
                    <circle cx="300" cy="210" r="44" fill="none" stroke-dasharray="6,4"
                            stroke-width="1.5" stroke="currentColor" opacity="0.25" />
                    <text x="300" y="207" text-anchor="middle" dominant-baseline="middle"
                          font-size="30" fill="currentColor" opacity="0.18">&#x29BF;</text>
                    <text x="300" y="280" text-anchor="middle"
                          font-size="14" font-weight="600" fill="currentColor" opacity="0.4">
                        No service dependencies detected
                    </text>
                    <text x="300" y="302" text-anchor="middle"
                          font-size="11" fill="currentColor" opacity="0.28">
                        Send traces with cross-service calls to see the map
                    </text>
                </g>
            }
            else
            {
                <!-- Draw edges first (behind nodes) -->
                @foreach (var edge in _edges)
                {
                    var fromPos = GetNodePosition(edge.Key.From);
                    var toPos = GetNodePosition(edge.Key.To);
                    var stats = edge.Value;
                    var errorRate = stats.CallCount > 0 ? (double)stats.ErrorCount / stats.CallCount : 0d;
                    var edgeColor = EdgeColor(errorRate);
                    var markerId = EdgeMarkerId(errorRate);
                    var strokeWidth = ScaleStrokeWidth(stats.CallCount);
                    var mid = Midpoint(fromPos, toPos);
                    var (fx, fy) = ShortenPoint(fromPos, toPos, 42);
                    var (tx, ty) = ShortenPoint(toPos, fromPos, 42);

                    <line x1="@(fx.ToString("0.##", CultureInfo.InvariantCulture))"
                          y1="@(fy.ToString("0.##", CultureInfo.InvariantCulture))"
                          x2="@(tx.ToString("0.##", CultureInfo.InvariantCulture))"
                          y2="@(ty.ToString("0.##", CultureInfo.InvariantCulture))"
                          stroke="@edgeColor"
                          stroke-width="@(strokeWidth.ToString("0.##", CultureInfo.InvariantCulture))"
                          stroke-linecap="round"
                          marker-end="@($"url(#{markerId})")"
                          opacity="0.85" />

                    <!-- Call count label at midpoint -->
                    <rect x="@((mid.X - 14).ToString("0.##", CultureInfo.InvariantCulture))"
                          y="@((mid.Y - 9).ToString("0.##", CultureInfo.InvariantCulture))"
                          width="28"
                          height="16"
                          rx="4"
                          ry="4"
                          fill="var(--panel-bg)"
                          stroke="@edgeColor"
                          stroke-width="1"
                          opacity="0.95" />
                     @((MarkupString)$"<text x=\"{mid.X.ToString("0.##", CultureInfo.InvariantCulture)}\" y=\"{(mid.Y + 1).ToString("0.##", CultureInfo.InvariantCulture)}\" text-anchor=\"middle\" dominant-baseline=\"middle\" font-size=\"9\" font-weight=\"700\" fill=\"{edgeColor}\">{FormatCount(stats.CallCount)}</text>")
                }

                <!-- Draw nodes on top -->
                @foreach (var node in _nodes)
                {
                    var pos = GetNodePosition(node.Key);
                    var ns = node.Value;
                    var nodeErrorRate = ns.TotalCalls > 0 ? (double)ns.ErrorCalls / ns.TotalCalls : 0d;
                    var nodeStroke = NodeStrokeColor(nodeErrorRate);
                    var label = TruncateLabel(node.Key, 14);
                    var avgMs = ns.TotalCalls > 0 ? ns.AvgDurationMs : 0d;
                    var avgLabel = avgMs < 1 ? "<1ms" : $"{(int)avgMs}ms";

                    <g class="service-node">
                        <!-- Outer glow ring for erroring nodes -->
                        @if (nodeErrorRate > 0.05)
                        {
                            <circle cx="@(pos.X.ToString("0.##", CultureInfo.InvariantCulture))"
                                    cy="@(pos.Y.ToString("0.##", CultureInfo.InvariantCulture))"
                                    r="46"
                                    fill="@nodeStroke"
                                    opacity="0.12" />
                        }
                        <!-- Node circle -->
                        <circle cx="@(pos.X.ToString("0.##", CultureInfo.InvariantCulture))"
                                cy="@(pos.Y.ToString("0.##", CultureInfo.InvariantCulture))"
                                r="40"
                                fill="var(--panel-bg)"
                                stroke="@nodeStroke"
                                stroke-width="2.5"
                                filter="url(#node-shadow)" />
                        <!-- Three-dot service icon -->
                        <circle cx="@((pos.X - 7).ToString("0.##", CultureInfo.InvariantCulture))"
                                cy="@((pos.Y - 5).ToString("0.##", CultureInfo.InvariantCulture))"
                                r="3"
                                fill="@nodeStroke"
                                opacity="0.7" />
                        <circle cx="@(pos.X.ToString("0.##", CultureInfo.InvariantCulture))"
                                cy="@((pos.Y - 5).ToString("0.##", CultureInfo.InvariantCulture))"
                                r="3"
                                fill="@nodeStroke"
                                opacity="0.7" />
                        <circle cx="@((pos.X + 7).ToString("0.##", CultureInfo.InvariantCulture))"
                                cy="@((pos.Y - 5).ToString("0.##", CultureInfo.InvariantCulture))"
                                r="3"
                                fill="@nodeStroke"
                                opacity="0.7" />
                        <!-- Avg latency inside node -->
                        <text x="@(pos.X.ToString("0.##", CultureInfo.InvariantCulture))"
                              y="@((pos.Y + 10).ToString("0.##", CultureInfo.InvariantCulture))"
                              text-anchor="middle"
                              dominant-baseline="middle"
                              font-size="9"
                              font-weight="500"
                              fill="var(--text-muted)">
                            @avgLabel
                        </text>
                        <!-- Service name label below node -->
                        <text x="@(pos.X.ToString("0.##", CultureInfo.InvariantCulture))"
                              y="@((pos.Y + 55).ToString("0.##", CultureInfo.InvariantCulture))"
                              text-anchor="middle"
                              dominant-baseline="middle"
                              font-size="11"
                              font-weight="600"
                              fill="var(--text-main)">
                            @label
                        </text>
                        <!-- Error count badge -->
                        @if (ns.ErrorCalls > 0)
                        {
                            <rect x="@((pos.X + 24).ToString("0.##", CultureInfo.InvariantCulture))"
                                  y="@((pos.Y - 42).ToString("0.##", CultureInfo.InvariantCulture))"
                                  width="22"
                                  height="14"
                                  rx="4"
                                  fill="#ef4444"
                                  opacity="0.92" />
                            @((MarkupString)$"<text x=\"{(pos.X + 35).ToString("0.##", CultureInfo.InvariantCulture)}\" y=\"{(pos.Y - 35).ToString("0.##", CultureInfo.InvariantCulture)}\" text-anchor=\"middle\" dominant-baseline=\"middle\" font-size=\"8\" font-weight=\"700\" fill=\"#fff\">{FormatCount(ns.ErrorCalls)}</text>")
                        }
                    </g>
                }
            }
        </svg>

        <!-- Legend -->
        <div class="legend">
            <span class="legend-title">Legend:</span>
            <div class="legend-item">
                <svg width="36" height="12" viewBox="0 0 36 12" overflow="visible">
                    <defs>
                        <marker id="la-h" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto" markerUnits="strokeWidth">
                            <polygon points="0 0, 8 3, 0 6" fill="#22c55e" />
                        </marker>
                    </defs>
                    <line x1="2" y1="6" x2="26" y2="6" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" marker-end="url(#la-h)" />
                </svg>
                <span>Healthy (&lt;5% errors)</span>
            </div>
            <div class="legend-item">
                <svg width="36" height="12" viewBox="0 0 36 12" overflow="visible">
                    <defs>
                        <marker id="la-d" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto" markerUnits="strokeWidth">
                            <polygon points="0 0, 8 3, 0 6" fill="#f59e0b" />
                        </marker>
                    </defs>
                    <line x1="2" y1="6" x2="26" y2="6" stroke="#f59e0b" stroke-width="2.5" stroke-linecap="round" marker-end="url(#la-d)" />
                </svg>
                <span>Degraded (5â€“20%)</span>
            </div>
            <div class="legend-item">
                <svg width="36" height="12" viewBox="0 0 36 12" overflow="visible">
                    <defs>
                        <marker id="la-f" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto" markerUnits="strokeWidth">
                            <polygon points="0 0, 8 3, 0 6" fill="#ef4444" />
                        </marker>
                    </defs>
                    <line x1="2" y1="6" x2="26" y2="6" stroke="#ef4444" stroke-width="2.5" stroke-linecap="round" marker-end="url(#la-f)" />
                </svg>
                <span>Failing (&gt;20%)</span>
            </div>
            <div class="legend-item">
                <svg width="20" height="20" viewBox="0 0 20 20">
                    <circle cx="10" cy="10" r="8" fill="var(--panel-bg)" stroke="var(--accent)" stroke-width="2" />
                </svg>
                <span>Service node</span>
            </div>
        </div>
    </div>

    <!-- Stats Table -->
    @if (_nodes.Count > 0)
    {
        <div class="table-section">
            <h2 class="section-title">Service Statistics</h2>
            <div class="aspire-table-container">
                <table class="aspire-table">
                    <thead>
                        <tr>
                            <th>Service</th>
                            <th>Total Calls</th>
                            <th>Errors</th>
                            <th>Error Rate</th>
                            <th>Avg Latency</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var node in _nodes.OrderByDescending(n => n.Value.TotalCalls))
                        {
                            var ns = node.Value;
                            var errRate = ns.TotalCalls > 0 ? (double)ns.ErrorCalls / ns.TotalCalls : 0d;
                            var errPct = (errRate * 100).ToString("0.#", CultureInfo.InvariantCulture);
                            var badgeClass = errRate > 0.20 ? "error" : errRate > 0.05 ? "warn" : "success";
                            var avgMs = ns.AvgDurationMs;
                            var avgStr = avgMs < 1 ? "< 1 ms" : $"{avgMs.ToString("0.#", CultureInfo.InvariantCulture)} ms";

                            <tr>
                                <td>
                                    <div class="service-cell">
                                        <span class="service-dot" style="background:@NodeStrokeColor(errRate)"></span>
                                        <span class="service-name" title="@node.Key">@node.Key</span>
                                    </div>
                                </td>
                                <td class="num-cell">@ns.TotalCalls.ToString("N0", CultureInfo.InvariantCulture)</td>
                                <td class="num-cell">@ns.ErrorCalls.ToString("N0", CultureInfo.InvariantCulture)</td>
                                <td>
                                    <span class="rate-badge @badgeClass">@errPct%</span>
                                </td>
                                <td class="mono-cell">@avgStr</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    .page-container {
        display: flex;
        flex-direction: column;
        gap: 1.75rem;
    }

    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .page-header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .page-header h1 {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0;
        color: var(--text-main);
        letter-spacing: -0.025em;
    }

    .summary-badge {
        font-size: 0.8rem;
        font-weight: 600;
        padding: 0.25rem 0.7rem;
        border-radius: 20px;
        background: var(--panel-bg-hover);
        color: var(--text-muted);
        border: 1px solid var(--border-color);
        white-space: nowrap;
    }

    .header-actions {
        display: flex;
        gap: 0.75rem;
        align-items: center;
    }

    .aspire-btn {
        background: var(--item-bg);
        border: 1px solid var(--border-color);
        color: var(--text-main);
        padding: 0.5rem 1rem;
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.9rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: background-color 0.15s, border-color 0.15s;
        font-family: inherit;
        line-height: 1;
    }

    .aspire-btn:hover {
        background: var(--panel-bg-hover);
    }

    .refresh-icon {
        width: 16px;
        height: 16px;
        fill: currentColor;
        flex-shrink: 0;
    }

    /* Graph card */
    .graph-card {
        background: var(--panel-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 24px -8px rgba(0, 0, 0, 0.08);
    }

    .service-map-svg {
        width: 100%;
        height: auto;
        display: block;
        color: var(--text-main);
    }

    /* Legend */
    .legend {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        padding: 0.85rem 1.5rem;
        border-top: 1px solid var(--border-color);
        background: var(--bg-color);
    }

    .legend-title {
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        white-space: nowrap;
    }

    .legend-item {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        font-size: 0.8rem;
        color: var(--text-muted);
        white-space: nowrap;
    }

    .legend-item svg {
        flex-shrink: 0;
        overflow: visible;
    }

    /* Table section */
    .table-section {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .section-title {
        font-size: 1.1rem;
        font-weight: 600;
        margin: 0;
        color: var(--text-main);
    }

    .aspire-table-container {
        background: var(--panel-bg);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 24px -8px rgba(0, 0, 0, 0.05);
    }

    .aspire-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.875rem;
    }

    .aspire-table th {
        background: var(--bg-color);
        color: var(--text-muted);
        font-weight: 600;
        text-align: left;
        padding: 0.75rem 1.25rem;
        border-bottom: 1px solid var(--border-color);
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        white-space: nowrap;
    }

    .aspire-table td {
        padding: 0.85rem 1.25rem;
        border-bottom: 1px solid var(--border-color);
        color: var(--text-main);
        vertical-align: middle;
    }

    .aspire-table tbody tr:hover td {
        background: var(--panel-bg-hover);
    }

    .aspire-table tbody tr:last-child td {
        border-bottom: none;
    }

    .service-cell {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .service-dot {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        flex-shrink: 0;
    }

    .service-name {
        font-weight: 600;
        color: var(--text-main);
        max-width: 260px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .num-cell {
        font-family: 'Consolas', 'Courier New', monospace;
        font-size: 0.85rem;
        white-space: nowrap;
    }

    .mono-cell {
        font-family: 'Consolas', 'Courier New', monospace;
        font-size: 0.85rem;
        white-space: nowrap;
    }

    .rate-badge {
        display: inline-block;
        padding: 0.2rem 0.55rem;
        border-radius: 20px;
        font-size: 0.78rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .rate-badge.success {
        background: var(--badge-success-bg);
        color: var(--badge-success-text);
    }

    .rate-badge.warn {
        background: rgba(245, 158, 11, 0.12);
        color: #d97706;
    }

    [data-theme="dark"] .rate-badge.warn {
        background: rgba(245, 158, 11, 0.15);
        color: #fbbf24;
    }

    .rate-badge.error {
        background: var(--badge-error-bg);
        color: var(--badge-error-text);
    }
</style>

@code {
    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    //  Internal models
    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    private sealed class EdgeStats
    {
        public int CallCount { get; set; }
        public int ErrorCount { get; set; }
        public double TotalDurationMs { get; set; }
    }

    private sealed class NodeStats
    {
        public int TotalCalls { get; set; }
        public int ErrorCalls { get; set; }
        public double SumDurationMs { get; set; }
        public double AvgDurationMs => TotalCalls > 0 ? SumDurationMs / TotalCalls : 0d;
    }

    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    //  State
    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    private Dictionary<(string From, string To), EdgeStats> _edges = new();
    private Dictionary<string, NodeStats> _nodes = new();
    private Dictionary<string, (double X, double Y)> _positions = new();
    private int _maxEdgeCalls = 1;

    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    //  Lifecycle
    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    protected override void OnInitialized()
    {
        Store.OnTelemetryReceived += OnTelemetryReceived;
        Recompute();
    }

    private void OnTelemetryReceived()
    {
        if (true)
        {
            InvokeAsync(() =>
            {
                Recompute();
                StateHasChanged();
            });
        }
    }

    public void Dispose()
    {
        Store.OnTelemetryReceived -= OnTelemetryReceived;
    }

    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    //  Graph computation
    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    private void Recompute()
    {
        var edges = new Dictionary<(string From, string To), EdgeStats>();
        var nodes = new Dictionary<string, NodeStats>(StringComparer.Ordinal);

        foreach (var trace in Store.Traces.Values)
        {
            // Build a lookup of spanId â†’ span for this trace
            var spanMap = new Dictionary<string, ParsedSpan>(StringComparer.Ordinal);
            foreach (var s in trace.AllSpans)
            {
                if (!string.IsNullOrEmpty(s.SpanId))
                    spanMap[s.SpanId] = s;
            }

            foreach (var span in trace.AllSpans)
            {
                var serviceName = string.IsNullOrEmpty(span.ServiceName) ? "Unknown" : span.ServiceName;

                // Ensure every service seen has a node entry
                if (!nodes.ContainsKey(serviceName))
                    nodes[serviceName] = new NodeStats();

                // Only consider cross-service edges via parent relationship
                if (string.IsNullOrEmpty(span.ParentSpanId))
                    continue;

                if (!spanMap.TryGetValue(span.ParentSpanId, out var parentSpan))
                    continue;

                var parentService = string.IsNullOrEmpty(parentSpan.ServiceName)
                    ? "Unknown"
                    : parentSpan.ServiceName;

                if (parentService == serviceName)
                    continue;

                // Ensure parent service has a node entry
                if (!nodes.ContainsKey(parentService))
                    nodes[parentService] = new NodeStats();

                var edgeKey = (parentService, serviceName);
                if (!edges.TryGetValue(edgeKey, out var edgeStats))
                {
                    edgeStats = new EdgeStats();
                    edges[edgeKey] = edgeStats;
                }

                var durationMs = span.Duration.TotalMilliseconds;
                edgeStats.CallCount++;
                edgeStats.TotalDurationMs += durationMs;
                if (span.IsError)
                    edgeStats.ErrorCount++;

                // Accumulate into destination node stats
                nodes[serviceName].TotalCalls++;
                nodes[serviceName].SumDurationMs += durationMs;
                if (span.IsError)
                    nodes[serviceName].ErrorCalls++;
            }
        }

        _edges = edges;
        _nodes = nodes;
        _maxEdgeCalls = edges.Count > 0 ? edges.Values.Max(e => e.CallCount) : 1;

        ComputePositions();
    }

    private void ComputePositions()
    {
        _positions = new Dictionary<string, (double X, double Y)>(StringComparer.Ordinal);

        var services = _nodes.Keys.OrderBy(s => s, StringComparer.Ordinal).ToList();
        int n = services.Count;
        if (n == 0)
            return;

        const double cx = 300;
        const double cy = 235;
        const double radius = 175;

        if (n == 1)
        {
            _positions[services[0]] = (cx, cy);
            return;
        }

        for (int i = 0; i < n; i++)
        {
            // Start at top (-PI/2) and go clockwise
            double angle = (2 * Math.PI * i / n) - (Math.PI / 2);
            double x = cx + radius * Math.Cos(angle);
            double y = cy + radius * Math.Sin(angle);
            _positions[services[i]] = (x, y);
        }
    }

    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
    //  SVG helpers
    // â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

    private (double X, double Y) GetNodePosition(string service)
    {
        if (_positions.TryGetValue(service, out var pos))
            return pos;
        return (300, 235);
    }

    /// <summary>
    /// Returns a point along the line from <paramref name="from"/> toward <paramref name="to"/>,
    /// offset <paramref name="margin"/> units back from <paramref name="from"/>.
    /// Used to make edge lines start/end at the circle rim rather than the centre.
    /// </summary>
    private static (double x, double y) ShortenPoint(
        (double X, double Y) from,
        (double X, double Y) to,
        double margin)
    {
        double dx = to.X - from.X;
        double dy = to.Y - from.Y;
        double len = Math.Sqrt(dx * dx + dy * dy);
        if (len < 0.001)
            return (from.X, from.Y);
        double ratio = (len - margin) / len;
        return (from.X + dx * ratio, from.Y + dy * ratio);
    }

    private static (double X, double Y) Midpoint((double X, double Y) a, (double X, double Y) b)
        => ((a.X + b.X) / 2.0, (a.Y + b.Y) / 2.0);

    private double ScaleStrokeWidth(int callCount)
    {
        const double minW = 1.5;
        const double maxW = 6.0;
        if (_maxEdgeCalls <= 1)
            return minW;
        double t = Math.Clamp((double)(callCount - 1) / (_maxEdgeCalls - 1), 0.0, 1.0);
        return minW + t * (maxW - minW);
    }

    private static string EdgeColor(double errorRate) => errorRate switch
    {
        > 0.20 => "#ef4444",
        > 0.05 => "#f59e0b",
        _      => "#22c55e"
    };

    private static string EdgeMarkerId(double errorRate) => errorRate switch
    {
        > 0.20 => "arrow-failing",
        > 0.05 => "arrow-degraded",
        _      => "arrow-healthy"
    };

    private static string NodeStrokeColor(double errorRate) => errorRate switch
    {
        > 0.20 => "#ef4444",
        > 0.05 => "#f59e0b",
        _      => "var(--accent)"
    };

    private static string TruncateLabel(string name, int maxLen)
        => name.Length <= maxLen ? name : string.Concat(name.AsSpan(0, maxLen), "\u2026");

    private static string FormatCount(int count) => count switch
    {
        >= 1_000_000 => $"{count / 1_000_000}M",
        >= 1_000     => $"{count / 1_000}k",
        _            => count.ToString()
    };
