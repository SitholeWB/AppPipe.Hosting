@page "/"
@page "/dashboard"
@using AppPipe.Hosting
@using Microsoft.Extensions.Configuration
@inject ITelemetryStore Store
@inject AppPipeHostingApp? AppTopology
@inject NavigationManager Nav
@inject IConfiguration Config
@implements IDisposable

<PageTitle>Resources - AppPipe.NET</PageTitle>

<div class="page-container">
    <div class="page-header">
        <h1>Resources</h1>
        <div class="header-actions">
            <a href="dashboard" class="aspire-btn" style="text-decoration:none; display:flex; align-items:center;">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M17.65 6.35A7.958 7.958 0 0012 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A5.99 5.99 0 0112 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"/></svg> Refresh
            </a>
        </div>
    </div>

    <!-- Overview Stats Grid -->
    <div class="stats-grid">
        <div class="aspire-card stats-card">
            <div class="stats-icon text-primary">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M5 12.55a11 11 0 0 1 14.08 0"></path><path d="M1.42 9a16 16 0 0 1 21.16 0"></path><path d="M8.58 16.12a5 5 0 0 1 6.84 0"></path><line x1="12" y1="20" x2="12.01" y2="20"></line></svg>
            </div>
            <div class="stats-details">
                <h3>Gateway Status</h3>
                <div class="stats-value text-success">
                    <span class="pulse-dot"></span> Active
                </div>
                <p class="stats-subtext">
                    IIS Site: @(AppTopology?.HostProject?.IISSiteName ?? "Kestrel Local")<br/>
                    VDir: @(AppTopology?.HostProject?.AppPath ?? "/")
                </p>
            </div>
        </div>
        
        <div class="aspire-card stats-card">
            <div class="stats-icon text-accent">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect><rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect><line x1="6" y1="6" x2="6.01" y2="6"></line><line x1="6" y1="18" x2="6.01" y2="18"></line></svg>
            </div>
            <div class="stats-details">
                <h3>Microservices</h3>
                <div class="stats-value">@(AppTopology?.Resources?.Count ?? 0) Resources</div>
                <p class="stats-subtext">
                    Projects: @(AppTopology?.Resources?.Count(r => r is AppPipeHostingProjectResource) ?? 0) | 
                    Execs: @(AppTopology?.Resources?.Count(r => r is ExecutableAppPipeHostingResource) ?? 0)
                </p>
            </div>
        </div>

        <div class="aspire-card stats-card">
            <div class="stats-icon text-warning">
                <svg viewBox="0 0 24 24" width="24" height="24" stroke="currentColor" stroke-width="2" fill="none"><path d="M22 12h-4l-3 9L9 3l-3 9H2"></path></svg>
            </div>
            <div class="stats-details">
                <h3>Telemetry Activity</h3>
                <div class="stats-value">@Store.Traces.Count Traces</div>
                <p class="stats-subtext">
                    Logs: @Store.Logs.Count | 
                    Metrics: @Store.Metrics.Count
                </p>
            </div>
        </div>
    </div>

    <!-- Overview Stats / Activity -->
    <div class="overview-section">
        <div class="aspire-card">
            <h3>Telemetry Activity</h3>
            <div class="graph-container">
                <svg class="activity-svg" preserveAspectRatio="none" viewBox="0 0 100 100">
                    @{
                        var now = DateTimeOffset.UtcNow;
                        var start = now.AddMinutes(-5); // Fixed 5 min window for overview
                        
                        // Bin traces into 50 buckets
                        int bucketCount = 50;
                        var buckets = new int[bucketCount];
                        var runningProjects = AppTopology?.Resources.Count() ?? 0;
                        var windowTicks = (now - start).Ticks;
                        
                        if (windowTicks > 0)
                        {
                            foreach (var t in Store.Traces.Values.Where(t => t.StartTime >= start))
                            {
                                var offset = (t.StartTime - start).Ticks;
                                var bucket = (int)((offset * bucketCount) / windowTicks);
                                if (bucket >= 0 && bucket < bucketCount)
                                {
                                    buckets[bucket]++;
                                }
                            }
                        }

                        int maxVal = buckets.Max();
                        if (maxVal == 0) maxVal = 1; 
                        
                        for (int i = 0; i < bucketCount; i++)
                        {
                            var height = (buckets[i] * 100.0) / maxVal;
                            var width = 100.0 / bucketCount;
                            var x = i * width;
                            var y = 100 - height;
                            
                            <rect x="@x" y="@y" width="@(width * 0.8)" height="@height" class="bar" />
                        }
                    }
                </svg>
            </div>
            <div class="graph-footer">
                <span class="text-muted">Last 5 Minutes</span>
                <span class="text-muted">Total Active Traces: @Store.Traces.Count</span>
            </div>
        </div>
    </div>

    <div class="aspire-table-container">
        <table class="aspire-table">
            <thead>
                <tr>
                    <th style="width: 250px">Name</th>
                    <th>Type</th>
                    <th style="width: 150px">State</th>
                    <th style="width: 200px">Last Telemetry</th>
                    <th style="width: 200px">Endpoints</th>
                </tr>
            </thead>
            <tbody>
                @if (AppTopology != null && AppTopology.HostProject != null)
                {
                    var isIIS = Environment.GetEnvironmentVariable("APP_POOL_ID") != null;
                    string endpointUrl;
                    if (isIIS)
                    {
                        var baseUriObj = new Uri(Nav.BaseUri);
                        var baseIISUrl = $"{baseUriObj.Scheme}://{baseUriObj.Authority}";
                        var appPath = AppTopology.HostProject.AppPath ?? "/";
                        if (!appPath.StartsWith("/")) appPath = "/" + appPath;
                        endpointUrl = $"{baseIISUrl}{appPath}";
                    }
                    else
                    {
                        endpointUrl = $"http://localhost:{AppTopology.HostProject.AssignedPort}";
                    }
                    <tr class="host-project-row">
                        <td class="fw-semibold">
                            <span class="host-indicator-dot" title="Host Gateway"></span>
                            @AppTopology.HostProject.Name <span class="host-tag">Host</span>
                        </td>
                        <td>HostProject</td>
                        <td><span class="status-badge host">Active</span></td>
                        <td class="text-muted" style="font-size:0.8rem;">Gateway</td>
                        <td><a href="@endpointUrl" target="_blank" class="endpoint-link">@endpointUrl</a></td>
                    </tr>
                }
                @if (AppTopology != null && AppTopology.Resources.Any())
                {
                    var lastSeen = GetLastSeenByService();
                    foreach (var resource in AppTopology.Resources)
                    {
                        var isIIS = Environment.GetEnvironmentVariable("APP_POOL_ID") != null;
                        string endpointUrl;
                        if (isIIS)
                        {
                            var baseUriObj = new Uri(Nav.BaseUri);
                            var baseIISUrl = $"{baseUriObj.Scheme}://{baseUriObj.Authority}";
                            var appPath = resource.AppPath ?? $"/{resource.Name}";
                            if (!appPath.StartsWith("/")) appPath = "/" + appPath;
                            endpointUrl = $"{baseIISUrl}{appPath}";
                        }
                        else
                        {
                            endpointUrl = $"http://localhost:{resource.AssignedPort}";
                        }

                        var hasActivity = lastSeen.TryGetValue(resource.Name, out var lastTs);
                        var isActive = hasActivity && (DateTimeOffset.UtcNow - lastTs).TotalSeconds < 60;
                        var lastSeenStr = hasActivity ? GetRelativeTime(lastTs) : "No telemetry yet";

                        <tr>
                            <td class="fw-semibold">@resource.Name</td>
                            <td>@(resource.GetType().Name.Replace("AppPipeHostingResource", "").Replace("Resource", ""))</td>
                            <td>
                                @if (isActive)
                                {
                                    <span class="status-badge success"><span class="pulse-dot" style="width:6px;height:6px;"></span> Active</span>
                                }
                                else if (hasActivity)
                                {
                                    <span class="status-badge warn">Idle</span>
                                }
                                else
                                {
                                    <span class="status-badge neutral">Running</span>
                                }
                            </td>
                            <td class="text-muted" style="font-size:0.8rem;">@lastSeenStr</td>
                            <td><a href="@endpointUrl" target="_blank" class="endpoint-link">@endpointUrl</a></td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-muted" style="text-align: center; padding: 2rem;">No resources detected</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Latency & Error Stats per Service -->
    @if (serviceStats.Any())
    {
        <div class="section-header"><h2>Service Performance</h2></div>
        <div class="aspire-table-container">
            <table class="aspire-table">
                <thead>
                    <tr>
                        <th>Service</th>
                        <th style="width:100px">Requests</th>
                        <th style="width:100px">Errors</th>
                        <th style="width:100px">Error Rate</th>
                        <th style="width:110px">P50</th>
                        <th style="width:110px">P95</th>
                        <th style="width:110px">P99</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var stat in serviceStats)
                    {
                        var errRate = stat.TotalRequests > 0 ? (stat.ErrorCount * 100.0 / stat.TotalRequests) : 0;
                        var errClass = errRate > 20 ? "badge-error" : errRate > 5 ? "badge-warn" : "badge-success";
                        <tr>
                            <td class="fw-semibold">@stat.ServiceName</td>
                            <td>@stat.TotalRequests</td>
                            <td>@stat.ErrorCount</td>
                            <td><span class="status-badge @errClass">@errRate.ToString("0.0")%</span></td>
                            <td class="font-mono">@stat.P50Ms ms</td>
                            <td class="font-mono">@stat.P95Ms ms</td>
                            <td class="font-mono">@stat.P99Ms ms</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- Data Retention -->
    <div class="section-header"><h2>Data Retention</h2></div>
    <div class="retention-grid">
        <div class="retention-card">
            <div class="retention-info">
                <span class="retention-label">Logs</span>
                <span class="retention-count">@Store.Logs.Count <span class="text-muted">/ 500</span></span>
            </div>
            <div class="retention-bar"><div class="retention-fill" style="width: @Math.Min(Store.Logs.Count * 100 / 500, 100)%"></div></div>
            <button class="aspire-btn danger-btn" @onclick="ClearLogs">Clear</button>
        </div>
        <div class="retention-card">
            <div class="retention-info">
                <span class="retention-label">Traces</span>
                <span class="retention-count">@Store.Traces.Count <span class="text-muted">/ 500</span></span>
            </div>
            <div class="retention-bar"><div class="retention-fill" style="width: @Math.Min(Store.Traces.Count * 100 / 500, 100)%"></div></div>
            <button class="aspire-btn danger-btn" @onclick="ClearTraces">Clear</button>
        </div>
        <div class="retention-card">
            <div class="retention-info">
                <span class="retention-label">Metric Batches</span>
                <span class="retention-count">@Store.Metrics.Count <span class="text-muted">/ 500</span></span>
            </div>
            <div class="retention-bar"><div class="retention-fill" style="width: @Math.Min(Store.Metrics.Count * 100 / 500, 100)%"></div></div>
            <button class="aspire-btn danger-btn" @onclick="ClearMetrics">Clear</button>
        </div>
    </div>
</div>


<style>
