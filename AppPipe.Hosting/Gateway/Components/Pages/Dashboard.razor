    @@keyframes pulse {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(34,197,94,0.7); }
        70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(34,197,94,0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(34,197,94,0); }
    }
    .host-project-row { background: rgba(2,132,199,0.02) !important; border-left: 3px solid var(--accent); }
    [data-theme="dark"] .host-project-row { background: rgba(56,189,248,0.02) !important; }
    .host-indicator-dot { display: inline-block; width: 8px; height: 8px; background-color: var(--accent); border-radius: 50%; margin-right: 8px; box-shadow: 0 0 8px var(--accent); }
    .host-tag { font-size: 0.7rem; background: var(--badge-info-bg); color: var(--badge-info-text); padding: 0.1rem 0.4rem; border-radius: 4px; margin-left: 8px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
    /* Retention */
    .retention-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1rem; }
    .retention-card { background: var(--panel-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 1rem 1.25rem; display: flex; flex-direction: column; gap: 0.6rem; }
    .retention-info { display: flex; justify-content: space-between; align-items: baseline; }
    .retention-label { font-weight: 600; font-size: 0.9rem; }
    .retention-count { font-size: 1.1rem; font-weight: 700; color: var(--text-main); }
    .retention-bar { height: 6px; background: var(--panel-bg-hover); border-radius: 3px; overflow: hidden; }
    .retention-fill { height: 100%; background: var(--accent); border-radius: 3px; transition: width 0.3s ease; }
</style>

@code {
    private record ServiceStat(string ServiceName, int TotalRequests, int ErrorCount, string P50Ms, string P95Ms, string P99Ms);
    private List<ServiceStat> serviceStats = new();

    protected override void OnInitialized()
    {
        Store.OnTelemetryReceived += OnTelemetryReceived;
        ComputeStats();
    }

    private void OnTelemetryReceived()
    {
        if (true)
        {
            InvokeAsync(() => { ComputeStats(); StateHasChanged(); });
        }
    }

    private void ComputeStats()
    {
        var grouped = Store.Traces.Values
            .SelectMany(t => t.AllSpans)
            .GroupBy(s => s.ServiceName);

        serviceStats = grouped.Select(g =>
        {
            var durations = g.Select(s => s.Duration.TotalMilliseconds).OrderBy(d => d).ToList();
            var total = durations.Count;
            var errors = g.Count(s => s.IsError);
            string Pct(int pct) => total == 0 ? "-" : Math.Round(durations[(int)Math.Floor((pct / 100.0) * (total - 1))], 1).ToString();
            return new ServiceStat(g.Key, total, errors, Pct(50), Pct(95), Pct(99));
        }).OrderBy(s => s.ServiceName).ToList();
    }

    private IReadOnlyDictionary<string, DateTimeOffset> GetLastSeenByService()
    {
        if (Store is InMemoryTelemetryStore mem)
            return mem.GetLastSeenByService();
        return new Dictionary<string, DateTimeOffset>();
    }

    private static string GetRelativeTime(DateTimeOffset ts)
    {
        var ago = DateTimeOffset.UtcNow - ts;
        if (ago.TotalSeconds < 60) return $"{(int)ago.TotalSeconds}s ago";
        if (ago.TotalMinutes < 60) return $"{(int)ago.TotalMinutes}m ago";
        return $"{(int)ago.TotalHours}h ago";
    }

    private void ClearLogs() { Store.ClearLogs(); ComputeStats(); }
    private void ClearTraces() { Store.ClearTraces(); ComputeStats(); }
    private void ClearMetrics() { Store.ClearMetrics(); ComputeStats(); }

    public void Dispose()
    {
        Store.OnTelemetryReceived -= OnTelemetryReceived;
    }
}
