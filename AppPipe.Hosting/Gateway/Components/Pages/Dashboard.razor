    .overview-section { display: grid; grid-template-columns: 1fr; gap: 1.5rem; }
    .aspire-card { background: var(--panel-bg); border: 1px solid var(--border-color); border-radius: 8px; padding: 1.25rem; }
    .aspire-card h3 { margin: 0 0 1rem 0; font-size: 1rem; font-weight: 600; color: var(--text-main); }
    .graph-container { height: 80px; width: 100%; }
    .activity-svg { width: 100%; height: 100%; overflow: visible; }
    .activity-svg .bar { fill: var(--accent); opacity: 0.8; transition: height 0.3s ease, y 0.3s ease; rx: 1; }
    .activity-svg .bar:hover { opacity: 1; fill: #0ea5e9; }
    .graph-footer { display: flex; justify-content: space-between; margin-top: 0.5rem; font-size: 0.8rem; }
    .fw-semibold { font-weight: 600; }
    .font-mono { font-family: 'Consolas', 'Courier New', monospace; font-size: 0.85rem; }
    .text-muted { color: var(--text-muted); }
    .status-badge { font-size: 0.8rem; font-weight: 600; padding: 0.2rem 0.5rem; border-radius: 4px; display: inline-flex; align-items: center; gap: 0.35rem; }
    .status-badge.success { background: var(--badge-success-bg); color: var(--badge-success-text); }
    .status-badge.warn { background: rgba(234,179,8,0.15); color: #ca8a04; }
    [data-theme="dark"] .status-badge.warn { color: #facc15; }
    .status-badge.neutral { background: var(--panel-bg-hover); color: var(--text-muted); }
    .status-badge.host { background: var(--badge-info-bg); color: var(--badge-info-text); }
    .status-badge.badge-error { background: var(--badge-error-bg); color: var(--badge-error-text); }
    .status-badge.badge-warn { background: rgba(234,179,8,0.15); color: #ca8a04; }
    .status-badge.badge-success { background: var(--badge-success-bg); color: var(--badge-success-text); }
