        display: flex;
        flex-direction: column;
        height: 100%;
        gap: 1.5rem;
    }
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .page-header h1 {
        font-size: 1.5rem;
        font-weight: 600;
        margin: 0;
    }
    .section-header {
        margin-top: 0.5rem;
    }
    .section-header h2 {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin: 0;
    }
    .aspire-btn {
        background: var(--item-bg);
        border: 1px solid var(--border-color);
        color: var(--text-main);
        padding: 0.4rem 1rem;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.9rem;
        font-weight: 500;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
    }
    .aspire-btn:hover { background: var(--panel-bg-hover); }
    .danger-btn {
        background: transparent;
        border-color: var(--badge-error-text);
        color: var(--badge-error-text);
        padding: 0.25rem 0.6rem;
        font-size: 0.75rem;
    }
