<Project>
  <PropertyGroup>
    <RequiresAspNetWebAssets>true</RequiresAspNetWebAssets>
  </PropertyGroup>
  <!-- Automatically inject decoupling metadata to ProjectReference items at the start of build configuration -->
  <!-- We skip AppPipe.Hosting.csproj itself -->
  <Target Name="ConfigureAppPipeProjectReferences" BeforeTargets="AssignProjectConfiguration;ResolveProjectReferences;BeforeBuild">
    <ItemGroup>
      <ProjectReference Condition="!$([System.String]::new('%(Identity)').Contains('AppPipe.Hosting.csproj'))">
        <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
        <SkipGetTargetFrameworkProperties>true</SkipGetTargetFrameworkProperties>
        <Private>false</Private>
        <PrivateAssets>All</PrivateAssets>
        <ExcludeAssets>All</ExcludeAssets>
        <Properties Condition="'%(ProjectReference.Properties)' != ''">%(ProjectReference.Properties);StaticWebAssetsEnabled=false</Properties>
        <Properties Condition="'%(ProjectReference.Properties)' == ''">StaticWebAssetsEnabled=false</Properties>
      </ProjectReference>
    </ItemGroup>
  </Target>

  <Target Name="GenerateAppPipeProjectConstants" BeforeTargets="BeforeCompile;CoreCompile">
    <PropertyGroup>
      <GeneratedProjectsFile>$(IntermediateOutputPath)AppPipe.Projects.g.cs</GeneratedProjectsFile>
    </PropertyGroup>
    
    <ItemGroup>
      <!-- Filter out the AppPipe.Hosting library reference itself and any project references that opted out of AppProject -->
      <FilteredProjectReference Include="@(ProjectReference)" Condition="!$([System.String]::new('%(Identity)').Contains('AppPipe.Hosting.csproj')) and '%(ProjectReference.AppProject)' != 'false'" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReferenceNames Include="@(FilteredProjectReference->'%(Filename)')">
        <ConstantName>$([System.String]::new('%(Filename)').Replace('.', '_').Replace('-', '_'))</ConstantName>
      </ProjectReferenceNames>
    </ItemGroup>

    <!-- Create code lines -->
    <ItemGroup>
      <CodeLines Include="// &lt;auto-generated /&gt;" />
      <CodeLines Include="namespace AppPipe.Hosting" />
      <CodeLines Include="{" />
      <CodeLines Include="    public static class AppPipeProjects" />
      <CodeLines Include="    {" />
      <CodeLines Include="        public const string %(ProjectReferenceNames.ConstantName) = &quot;%(ProjectReferenceNames.Identity)&quot;%3B" />
      <CodeLines Include="    }" />
      <CodeLines Include="}" />
    </ItemGroup>

    <!-- Write code lines to the intermediate directory file, overwriting the old one -->
    <WriteLinesToFile File="$(GeneratedProjectsFile)" Lines="@(CodeLines)" Overwrite="true" WriteOnlyWhenDifferent="true" />
    
    <ItemGroup>
      <!-- Include the generated file in the compilation dynamically -->
      <Compile Include="$(GeneratedProjectsFile)" />
    </ItemGroup>
  </Target>
</Project>
