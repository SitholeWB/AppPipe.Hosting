{
  "$schema": "http://json.schemastore.org/template",
  "author": "AppPipe",
  "classifications": [ "Common", "Console", "Web", "Orchestrator", "Gateway", "Solution" ],
  "name": "AppPipe Application Hosting",
  "identity": "AppPipe.Hosting.System.Template",
  "shortName": "app-pipe",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "AppPipeSystem",
  "preferNameDirectory": true,
  "primaryOutputs": [
    { "path": "AppPipeSystem.sln" }
  ],
  "symbols": {
    "architecture": {
      "type": "parameter",
      "dataType": "choice",
      "defaultValue": "simple",
      "description": "Choose the architecture pattern for the BackendApi.",
      "choices": [
        {
          "choice": "simple",
          "description": "Scaffolds a simple Minimal API structure."
        },
        {
          "choice": "clean-cqrs",
          "description": "Scaffolds a Clean Architecture + CQRS API."
        }
      ]
    },
    "database": {
      "type": "parameter",
      "dataType": "choice",
      "defaultValue": "none",
      "description": "Choose the database provider for the BackendApi.",
      "choices": [
        { "choice": "none", "description": "No database context." },
        { "choice": "sqlite", "description": "SQLite EF Core context." },
        { "choice": "postgresql", "description": "PostgreSQL EF Core context." },
        { "choice": "sqlserver", "description": "SQL Server EF Core context." }
      ]
    },
    "frontend": {
      "type": "parameter",
      "dataType": "choice",
      "defaultValue": "blazor",
      "description": "Choose the frontend web framework.",
      "choices": [
        { "choice": "blazor", "description": "Blazor Web App with Server SSR." },
        { "choice": "htmx", "description": "Razor Pages + HTMX web app." }
      ]
    },
    "auth": {
      "type": "parameter",
      "dataType": "choice",
      "defaultValue": "none",
      "description": "Choose authentication type.",
      "choices": [
        { "choice": "none", "description": "No authentication configured." },
        { "choice": "jwt", "description": "JWT Bearer authentication on BackendApi." }
      ]
    },
    "caching": {
      "type": "parameter",
      "dataType": "choice",
      "defaultValue": "none",
      "description": "Choose caching provider.",
      "choices": [
        { "choice": "none", "description": "No caching configured." },
        { "choice": "redis", "description": "Redis distributed caching." }
      ]
    },
    "UseSqlite": {
      "type": "computed",
      "value": "database == \"sqlite\""
    },
    "UsePostgres": {
      "type": "computed",
      "value": "database == \"postgresql\""
    },
    "UseSqlServer": {
      "type": "computed",
      "value": "database == \"sqlserver\""
    },
    "UseDatabase": {
      "type": "computed",
      "value": "database != \"none\""
    },
    "UseBlazor": {
      "type": "computed",
      "value": "frontend == \"blazor\""
    },
    "UseHtmx": {
      "type": "computed",
      "value": "frontend == \"htmx\""
    },
    "UseJwtAuth": {
      "type": "computed",
      "value": "auth == \"jwt\""
    },
    "UseRedis": {
      "type": "computed",
      "value": "caching == \"redis\""
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "condition": "(architecture == \"simple\")",
          "exclude": [
            "AppPipeSystem.Domain/**",
            "AppPipeSystem.Application/**",
            "AppPipeSystem.Infrastructure/**",
            "AppPipeSystem.CleanBackendApi/**",
            "AppPipeSystem.clean.sln"
          ],
          "rename": {
            "AppPipeSystem.simple.sln": "AppPipeSystem.sln"
          }
        },
        {
          "condition": "(architecture == \"clean-cqrs\")",
          "exclude": [
            "AppPipeSystem.BackendApi/**",
            "AppPipeSystem.simple.sln"
          ],
          "rename": {
            "AppPipeSystem.clean.sln": "AppPipeSystem.sln",
            "AppPipeSystem.CleanBackendApi/AppPipeSystem.CleanBackendApi.csproj": "AppPipeSystem.BackendApi/AppPipeSystem.BackendApi.csproj",
            "AppPipeSystem.CleanBackendApi": "AppPipeSystem.BackendApi"
          }
        },
        {
          "condition": "(frontend == \"blazor\")",
          "exclude": [
            "AppPipeSystem.HtmxWeb/**"
          ],
          "rename": {
            "AppPipeSystem.BlazorWeb/AppPipeSystem.BlazorWeb.csproj": "AppPipeSystem.Web/AppPipeSystem.Web.csproj",
            "AppPipeSystem.BlazorWeb": "AppPipeSystem.Web"
          }
        },
        {
          "condition": "(frontend == \"htmx\")",
          "exclude": [
            "AppPipeSystem.BlazorWeb/**"
          ],
          "rename": {
            "AppPipeSystem.HtmxWeb/AppPipeSystem.HtmxWeb.csproj": "AppPipeSystem.Web/AppPipeSystem.Web.csproj",
            "AppPipeSystem.HtmxWeb": "AppPipeSystem.Web"
          }
        }
      ]
    }
  ]
}

